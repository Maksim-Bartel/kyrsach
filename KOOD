    crew.push_back(CrewMember(nextCrewId++, "Иван Петров", Rank::COMMANDER));
    crew.push_back(CrewMember(nextCrewId++, "Мария Иванова", Rank::ENGINEER));
    crew.push_back(CrewMember(nextCrewId++, "Алексей Смирнов", Rank::SCIENTIST));
