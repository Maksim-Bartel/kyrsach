#ifndef STATION_EXCEPTION_H
#define STATION_EXCEPTION_H
#include <exception>
#include <string>
using namespace std;

class StationException : public exception {
private:
    string message;
public:
    explicit StationException(const string& msg) : message(msg) {}

    const char* what() const noexcept override {
        return message.c_str();
    }
};

#endif
